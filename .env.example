OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Claude provider ────────────────────────────────────────────────
# "anthropic" = Anthropic 직접 API (ANTHROPIC_API_KEY 사용)
# "bedrock"   = AWS Bedrock (AWS 크레딧 차감, AWS 자격증명 사용)
CLAUDE_PROVIDER=anthropic

# CLAUDE_PROVIDER=anthropic 일 때 필요
ANTHROPIC_API_KEY=

# CLAUDE_PROVIDER=bedrock 일 때 필요
# Bedrock 장기 API 키 (콘솔에서 발급) 또는 표준 AWS 자격증명
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=ap-northeast-2
# 교차 리전 추론 프로파일 id (Sonnet 4.6 = global.* 프로파일)
CLAUDE_BEDROCK_MODEL=global.anthropic.claude-sonnet-4-6

LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=team4-ko-safety
